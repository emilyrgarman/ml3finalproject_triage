    {
      "cell_type": "code",
      "source": [
        "import numpy as np\n",
        "import pandas as pd\n",
        "from sklearn.model_selection import train_test_split\n",
        "from sklearn.preprocessing import StandardScaler, LabelEncoder\n",
        "from sklearn.impute import SimpleImputer\n",
        "\n",
        "SEED = 42"
      ],
      "metadata": {
        "id": "47pxwehQZFnk"
      },
      "execution_count": 3,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "source": [
        "Loading in and merging train and test sets with chief complaints text data"
      ],
      "metadata": {
        "id": "2OBVzszRgzrN"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "train = pd.read_csv('/content/ml3finalproject_triage/train.csv')\n",
        "test = pd.read_csv('/content/ml3finalproject_triage/test.csv')\n",
        "complaints = pd.read_csv('/content/ml3finalproject_triage/chief_complaints.csv')\n",
        "history = pd.read_csv('/content/ml3finalproject_triage/patient_history.csv')"
      ],
      "metadata": {
        "id": "Zi7K8WhIZEcS"
      },
      "execution_count": 4,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "train_df = train.merge(complaints[['patient_id', 'chief_complaint_raw']], on='patient_id', how='left')\n",
        "train_df = train_df.merge(history, on='patient_id', how='left')\n",
        "test_df  = test.merge(complaints[['patient_id', 'chief_complaint_raw']], on='patient_id', how='left')\n",
        "test_df = test_df.merge(history, on='patient_id', how='left')"
      ],
      "metadata": {
        "id": "_bNklo_RgSEl"
      },
      "execution_count": 5,
      "outputs": []
    },
